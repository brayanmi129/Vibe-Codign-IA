{
  "entities": {
    "Store": {
      "title": "Store",
      "description": "A store tenant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "businessType": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "branding": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "secondaryColor": { "type": "string" },
            "backgroundColor": { "type": "string" }
          }
        }
      },
      "required": ["id", "name", "ownerId", "createdAt"]
    },
    "StoreMember": {
      "title": "Store Member",
      "description": "User association with a store and their role",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee", "viewer"] },
        "email": { "type": "string" },
        "displayName": { "type": "string" }
      },
      "required": ["userId", "role", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the store's inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "minStockLevel": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "storeId", "code", "name", "price", "quantity"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A sales transaction in a store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "totalPrice": { "type": "number" }
            }
          }
        },
        "userId": { "type": "string" }
      },
      "required": ["id", "storeId", "date", "totalAmount", "items", "userId"]
    },
    "Restock": {
      "title": "Restock",
      "description": "A product restock entry in a store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["id", "storeId", "productId", "quantity", "date", "userId"]
    }
  },
  "firestore": {
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Tenant store information"
    },
    "/stores/{storeId}/members/{userId}": {
      "schema": "StoreMember",
      "description": "Store users and their roles"
    },
    "/stores/{storeId}/products/{productId}": {
      "schema": "Product",
      "description": "Store-specific product catalog"
    },
    "/stores/{storeId}/sales/{saleId}": {
      "schema": "Sale",
      "description": "Store-specific sales transactions"
    },
    "/stores/{storeId}/restocks/{restockId}": {
      "schema": "Restock",
      "description": "Store-specific inventory restock history"
    }
  }
}
