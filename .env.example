# GROQ_API_KEY (recomendado): proveedor primario de IA.
# Free tier sin tarjeta — 30 req/min, 14.400 req/día.
# Obtenla en: https://console.groq.com/keys
GROQ_API_KEY="MY_GROQ_API_KEY"

# GEMINI_API_KEY (opcional): se usa como FALLBACK si Groq falla.
# Si no la tienes (o tu proyecto está bloqueado con limit:0), déjala vacía
# y el sistema funciona solo con Groq.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Supabase — Storage para imágenes y facturas PDF
# Obtenlos en: https://supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL="https://.....supabase.co"
VITE_SUPABASE_ANON_KEY="eyasasdsd...."
