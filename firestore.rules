rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    function isStoreMember(storeId) {
      return isSignedIn() && exists(/databases/$(database)/documents/stores/$(storeId)/members/$(request.auth.uid));
    }

    function getStoreRole(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)/members/$(request.auth.uid)).data.role;
    }

    function hasAdminRole(storeId) {
      return isStoreMember(storeId) && getStoreRole(storeId) == 'admin';
    }

    function hasEmployeeRole(storeId) {
      return isStoreMember(storeId) && (getStoreRole(storeId) == 'admin' || getStoreRole(storeId) == 'employee');
    }

    function hasViewerRole(storeId) {
      return isStoreMember(storeId) || isStoreOwner(storeId);
    }

    // Rules for Stores
    match /stores/{storeId} {
      // Allow get if owner or member
      allow get: if isStoreMember(storeId) || isStoreOwner(storeId);
      // Allow list only if querying by ownerId (for the demo/admin fetch)
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn(); 
      allow update: if hasAdminRole(storeId) || isStoreOwner(storeId);
      allow delete: if false;

      match /members/{userId} {
        allow read: if isStoreMember(storeId) || isStoreOwner(storeId);
        allow write: if hasAdminRole(storeId) || isStoreOwner(storeId) || (isSignedIn() && request.auth.uid == userId);
      }

      match /products/{productId} {
        allow read: if hasViewerRole(storeId);
        allow write: if hasEmployeeRole(storeId);
      }

      match /sales/{saleId} {
        allow read: if hasViewerRole(storeId);
        allow create: if hasEmployeeRole(storeId);
        allow update, delete: if hasAdminRole(storeId);
      }

      match /restocks/{restockId} {
        allow read: if hasViewerRole(storeId);
        allow write: if hasEmployeeRole(storeId);
      }
    }

    // Global user profiles
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
