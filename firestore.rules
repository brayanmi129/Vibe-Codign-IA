rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Special check for demo users who might be in a restricted environment
    function isDemoUID(uid) {
      return uid == "demo-user-123" || uid == "demo-employee-456";
    }

    function isStoreOwner(storeId) {
      return (isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid)
             || (storeId == "stockmaster-ai-demo" && request.auth == null); // Allow demo bypass if no auth
    }

    function isStoreMember(storeId) {
      return (storeId == "stockmaster-ai-demo" && request.auth == null) || 
             (isSignedIn() && exists(/databases/$(database)/documents/stores/$(storeId)/members/$(request.auth.uid)));
    }

    function getStoreRole(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)/members/$(request.auth.uid)).data.role;
    }

    function hasAdminRole(storeId) {
      return (storeId == "stockmaster-ai-demo" && request.auth == null) || 
             (isStoreMember(storeId) && getStoreRole(storeId) == 'admin');
    }

    function hasEmployeeRole(storeId) {
      return (storeId == "stockmaster-ai-demo" && request.auth == null) || 
             (isStoreMember(storeId) && (getStoreRole(storeId) == 'admin' || getStoreRole(storeId) == 'employee'));
    }

    function hasViewerRole(storeId) {
      return isStoreMember(storeId) || isStoreOwner(storeId);
    }

    // Rules for Stores
    match /stores/{storeId} {
      allow get: if hasViewerRole(storeId) || storeId == "stockmaster-ai-demo";
      allow list: if (isSignedIn() && (resource.data.ownerId == request.auth.uid || exists(/databases/$(database)/documents/stores/$(storeId)/members/$(request.auth.uid))))
                  || storeId == "stockmaster-ai-demo";
      
      allow create: if isSignedIn() || (request.resource.data.ownerId == "demo-user-123"); 
      allow update: if hasAdminRole(storeId) || isStoreOwner(storeId) || storeId == "stockmaster-ai-demo";
      allow delete: if false;

      match /members/{userId} {
        allow read: if hasViewerRole(storeId) || isDemoUID(userId);
        allow write: if isStoreOwner(storeId) || hasAdminRole(storeId) || (isSignedIn() && request.auth.uid == userId) || isDemoUID(userId);
      }

      match /products/{productId} {
        allow read: if hasViewerRole(storeId) || storeId == "stockmaster-ai-demo";
        allow write: if isStoreOwner(storeId) || hasEmployeeRole(storeId) || storeId == "stockmaster-ai-demo";
      }

      match /sales/{saleId} {
        allow read: if hasViewerRole(storeId) || storeId == "stockmaster-ai-demo";
        allow create: if isStoreOwner(storeId) || hasEmployeeRole(storeId) || storeId == "stockmaster-ai-demo";
        allow update, delete: if isStoreOwner(storeId) || hasAdminRole(storeId) || storeId == "stockmaster-ai-demo";
      }

      match /restocks/{restockId} {
        allow read: if hasViewerRole(storeId) || storeId == "stockmaster-ai-demo";
        allow write: if isStoreOwner(storeId) || hasEmployeeRole(storeId) || storeId == "stockmaster-ai-demo";
      }
    }

    // Global user profiles
    match /users/{userId} {
      allow read, write: if (isSignedIn() && request.auth.uid == userId) || isDemoUID(userId);
      match /{allSubcollections=**} {
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || isDemoUID(userId);
      }
    }
  }
}
