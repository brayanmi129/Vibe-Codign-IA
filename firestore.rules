rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Helper Functions ─────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isDemoUID(uid) {
      return uid == "demo-user-123" || uid == "demo-employee-456";
    }

    // Email-based super admin check — works with any auth provider (Google OAuth or email/password)
    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/superadmins/$(request.auth.token.email));
    }

    function emailKey() {
      // Document IDs in stores/{storeId}/members are the email with '.' → '_'.
      return request.auth.token.email.replace('.', '_');
    }

    function isStoreOwner(storeId) {
      return (isSignedIn() &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid)
        || (storeId == "stockmaster-ai-demo" && request.auth == null);
    }

    function isStoreMember(storeId) {
      return (storeId == "stockmaster-ai-demo" && request.auth == null) ||
        (isSignedIn() &&
          exists(/databases/$(database)/documents/stores/$(storeId)/members/$(emailKey())));
    }

    function getStoreRole(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)/members/$(emailKey())).data.role;
    }

    function hasAdminRole(storeId) {
      return (storeId == "stockmaster-ai-demo" && request.auth == null) ||
        (isStoreMember(storeId) && getStoreRole(storeId) == 'admin');
    }

    function hasEmployeeRole(storeId) {
      return (storeId == "stockmaster-ai-demo" && request.auth == null) ||
        (isStoreMember(storeId) &&
          (getStoreRole(storeId) == 'admin' || getStoreRole(storeId) == 'employee'));
    }

    function hasViewerRole(storeId) {
      return isStoreMember(storeId) || isStoreOwner(storeId);
    }

    // ─── Super Admins collection ──────────────────────────────────────
    // Document ID = email address. Works with any auth provider.
    // The seed admin (admin@stockmaster.ai) can write during setup.
    // Any signed-in user can GET their own super-admin record (needed for the
    // first-login auth-method check before the user is fully resolved).
    match /superadmins/{email} {
      allow get: if (isSignedIn() && request.auth.token.email == email) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create, update: if isSignedIn() && (
        isSuperAdmin() ||
        request.auth.token.email == "admin@stockmaster.ai"
      );
      // The user themselves can clear their own tempPassword on first login.
      allow update: if isSignedIn() && request.auth.token.email == email;
      allow delete: if isSuperAdmin();
    }

    // ─── Stores ───────────────────────────────────────────────────────
    match /stores/{storeId} {
      allow get: if hasViewerRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
      allow list: if isSuperAdmin() ||
        (isSignedIn() && (
          resource.data.ownerId == request.auth.uid ||
          exists(/databases/$(database)/documents/stores/$(storeId)/members/$(emailKey()))
        )) ||
        storeId == "stockmaster-ai-demo";

      allow create: if isSignedIn() || (request.resource.data.ownerId == "demo-user-123");
      allow update: if hasAdminRole(storeId) || isStoreOwner(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
      allow delete: if isStoreOwner(storeId) || hasAdminRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";

      match /branches/{branchId} {
        allow read: if hasViewerRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
        allow write: if isStoreOwner(storeId) || hasAdminRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
      }

      // Members: stored by email-key. Admin of the store writes; the member
      // himself can update his own doc (to bind userId / clear tempPassword on first login).
      match /members/{memberKey} {
        allow read: if isStoreMember(storeId) || isStoreOwner(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
        allow write: if isStoreOwner(storeId) || hasAdminRole(storeId) || isSuperAdmin() ||
          (isSignedIn() && memberKey == emailKey()) ||
          isDemoUID(memberKey) ||
          storeId == "stockmaster-ai-demo";
      }

      match /products/{productId} {
        allow read: if hasViewerRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
        allow write: if isStoreOwner(storeId) || hasEmployeeRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
      }

      match /sales/{saleId} {
        allow read: if hasViewerRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
        allow create: if isStoreOwner(storeId) || hasEmployeeRole(storeId) || storeId == "stockmaster-ai-demo";
        allow update, delete: if isStoreOwner(storeId) || hasAdminRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
      }

      match /restocks/{restockId} {
        allow read: if hasViewerRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
        allow write: if isStoreOwner(storeId) || hasEmployeeRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
      }

      match /expenses/{expenseId} {
        allow read: if hasViewerRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
        allow write: if isStoreOwner(storeId) || hasAdminRole(storeId) || isSuperAdmin() || storeId == "stockmaster-ai-demo";
      }
    }

    // ─── Cross-tenant member lookup ───────────────────────────────────
    // collectionGroup('members') queries are needed for two flows:
    //   1. First-login binding: a user just authenticated and we look up their
    //      pre-registration by email to find which store they belong to.
    //   2. "Email free" validation before adding a new member or super admin.
    //
    // Both cases require any signed-in user to read members. Filtering happens
    // client-side by 'email' field; an attacker still needs to know the target
    // email to learn anything from this. tempPassword leaks to anyone who can
    // guess an email — acceptable trade-off in this client-only architecture.
    match /{path=**}/members/{memberKey} {
      allow read: if isSignedIn();
    }

    // ─── User profiles ────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if
        (isSignedIn() && request.auth.uid == userId) ||
        isDemoUID(userId) ||
        isSuperAdmin();

      match /{allSubcollections=**} {
        allow read, write: if
          (isSignedIn() && request.auth.uid == userId) ||
          isDemoUID(userId) ||
          isSuperAdmin();
      }
    }
  }
}
